# Supabase 数据库（必填）
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-publishable-key
COZE_SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# Drizzle 直连数据库（选填，仅本地 db:push / db:generate 需要）
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# 对象存储 — Vercel / 自建部署强烈建议配置（Cloudflare R2 等）
COZE_BUCKET_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
COZE_BUCKET_NAME=love-diary
COZE_BUCKET_ACCESS_KEY=your-access-key
COZE_BUCKET_SECRET_KEY=your-secret-key
COZE_BUCKET_REGION=auto

# 也可用标准 AWS 变量名（与上面二选一）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# 高德地图（国内地点搜索 / 空间 Tab / 国内逆地理优先）
# Key 类型须为「Web端(JS API)」
# 控制台域名白名单务必加入：localhost、726love.vercel.app、以及你的自定义域名
NEXT_PUBLIC_AMAP_KEY=
# 2.0 安全密钥（JS API Key 详情页获取，与 Key 配对使用）
NEXT_PUBLIC_AMAP_SECURITY_CODE=

# 海外 GPS 逆地理：无需额外 Key
# 国内优先高德；失败或海外坐标自动兜底 BigDataCloud / OpenStreetMap Nominatim
