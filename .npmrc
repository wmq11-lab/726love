loglevel=error
registry=https://registry.npmmirror.com

strictStorePkgContentCheck=false
verifyStoreIntegrity=false

# 网络优化
network-concurrency=16
fetch-retries=3
fetch-timeout=60000

# 严格使用 peer dependencies
strict-peer-dependencies=false

# 自动生成 lockfile
auto-install-peers=true

# lockfile 配置
lockfile=true
prefer-frozen-lockfile=true

# 如果 lockfile 存在但过期，更新而不是失败
resolution-mode=highest

# 不提示 npm 更新
update-notifier=false

# 单包项目：避免被误判为 workspace 根而拦截 install
ignore-workspace-root-check=true

# Vercel (linux) 安装 sharp 原生 optional 包；勿用 outputFileTracingIncludes 打包 node_modules（pnpm  symlink 会导致部署失败）
supported-architectures.os=current,linux
supported-architectures.cpu=current,x64,arm64
supported-architectures.libc=current,glibc
